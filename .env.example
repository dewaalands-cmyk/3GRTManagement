# ============================================
# 3GRT MANAGEMENT — Environment Variables
# ============================================

# PRODUCTION: Neon PostgreSQL — pooled (untuk query runtime di Vercel)
# Dari: console.neon.tech → project → Connect → Prisma → salin DATABASE_URL
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# PRODUCTION: Neon direct connection (untuk prisma db push / migrate)
# Sama seperti DATABASE_URL tapi hostname tanpa -pooler
DIRECT_URL="postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# Kunci rahasia sesi login admin (min 32 karakter acak)
SESSION_SECRET="ganti-dengan-string-acak-panjang-minimal-32-karakter"
