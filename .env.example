# ============================================
# 3GRT MANAGEMENT — Environment Variables
# ============================================

# LOCAL: SQLite (tidak perlu diubah untuk dev lokal)
DATABASE_URL="file:./prisma/dev.db"

# PRODUCTION: Turso (libSQL cloud)
# Dapat dari: https://turso.tech → database → connect
TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# Kunci rahasia untuk sesi login admin (acak & panjang, min 32 karakter)
# Generate: openssl rand -base64 32
SESSION_SECRET="ganti-dengan-string-acak-panjang-minimal-32-karakter"
