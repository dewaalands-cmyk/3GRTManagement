generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String?
  passwordHash String
  createdAt    DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  type      String   @default("kontak")
  name      String
  contact   String
  role      String?
  subject   String?
  message   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model Event {
  id          String   @id @default(cuid())
  title       String
  badge       String?
  date        String
  location    String?
  description String?
  imageUrl    String?
  link        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Gallery {
  id        String   @id @default(cuid())
  title     String
  type      String   @default("video")
  youtubeId String?
  imageUrl  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  quote     String
  name      String
  role      String?
  rating    Int      @default(5)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Partner {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String?
  url       String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Service {
  id            String   @id @default(cuid())
  title         String
  description   String
  imageUrl      String?
  imagePosition String   @default("right")
  order         Int      @default(0)
  createdAt     DateTime @default(now())
}

model Package {
  id          String   @id @default(cuid())
  name        String
  price       String
  description String?
  features    String
  highlighted Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model SiteContent {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Merchandise {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       String?
  mediaUrl    String?
  link        String?
  badge       String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}
